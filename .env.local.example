# =============================================================================
# Zyflex Frontend – Environment Variables
# Kopiér til .env.local og udfyld
# =============================================================================

# URL til Zyflex AI backend
# Lokal udvikling: http://localhost:8000
# Produktion (Render/Railway): https://din-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Valgfri: Sæt til "true" for at aktivere demo-mode (statiske data, ingen backend krævet)
NEXT_PUBLIC_DEMO_MODE=false
